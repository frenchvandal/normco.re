{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normco.re/schemas/feed.json",
  "title": "JSON Feed",
  "description": "JSON Feed 1.1 output contract for normco.re feeds.",
  "type": "object",
  "required": [
    "version",
    "title",
    "home_page_url",
    "feed_url",
    "language",
    "items"
  ],
  "properties": {
    "version": {
      "const": "https://jsonfeed.org/version/1.1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "home_page_url": {
      "type": "string",
      "format": "uri"
    },
    "feed_url": {
      "type": "string",
      "format": "uri"
    },
    "language": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "oneOf": [
          { "required": ["content_html"] },
          { "required": ["content_text"] }
        ],
        "properties": {
          "id": { "type": "string", "format": "uri" },
          "url": { "type": "string", "format": "uri" },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" },
          "content_html": { "type": "string" },
          "content_text": { "type": "string" },
          "date_published": { "type": "string", "format": "date-time" },
          "date_modified": { "type": "string", "format": "date-time" },
          "language": {
            "type": "string",
            "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
