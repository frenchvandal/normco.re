{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normco.re/schemas/app-manifest.json",
  "title": "App Manifest",
  "description": "Bootstraps native clients with available locales and top-level content entrypoints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAt",
    "defaultLanguage",
    "languages",
    "postsIndex"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "defaultLanguage": {
      "$ref": "#/$defs/languageCode"
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/languageCode"
      }
    },
    "postsIndex": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/indexPointer"
      }
    }
  },
  "$defs": {
    "languageCode": {
      "type": "string",
      "enum": [
        "en",
        "fr",
        "zh-hans",
        "zh-hant"
      ]
    },
    "indexPointer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lang",
        "apiUrl"
      ],
      "properties": {
        "lang": {
          "$ref": "#/$defs/languageCode"
        },
        "apiUrl": {
          "type": "string",
          "pattern": "^/"
        }
      }
    }
  }
}
