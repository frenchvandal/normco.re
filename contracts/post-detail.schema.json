{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normco.re/schemas/post-detail.json",
  "title": "Post Detail",
  "description": "Localized post detail payload for native clients.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "slug",
    "lang",
    "title",
    "summary",
    "publishedAt",
    "updatedAt",
    "alternates",
    "webUrl",
    "blocks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "lang": {
      "$ref": "#/$defs/languageCode"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "readingTime": {
      "type": "integer",
      "minimum": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alternates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/alternate"
      }
    },
    "heroImage": {
      "oneOf": [
        {
          "$ref": "#/$defs/remoteImage"
        },
        {
          "type": "null"
        }
      ]
    },
    "webUrl": {
      "type": "string",
      "format": "uri"
    },
    "blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/block"
      }
    }
  },
  "$defs": {
    "languageCode": {
      "type": "string",
      "enum": [
        "en",
        "fr",
        "zh-hans",
        "zh-hant"
      ]
    },
    "remoteImage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "alt"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "alt": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "alternate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lang",
        "apiUrl",
        "webUrl"
      ],
      "properties": {
        "lang": {
          "$ref": "#/$defs/languageCode"
        },
        "apiUrl": {
          "type": "string",
          "pattern": "^/"
        },
        "webUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "block": {
      "oneOf": [
        {
          "$ref": "#/$defs/paragraphBlock"
        },
        {
          "$ref": "#/$defs/headingBlock"
        },
        {
          "$ref": "#/$defs/codeBlock"
        },
        {
          "$ref": "#/$defs/imageBlock"
        },
        {
          "$ref": "#/$defs/quoteBlock"
        },
        {
          "$ref": "#/$defs/listBlock"
        }
      ]
    },
    "paragraphBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "paragraph"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "headingBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "level",
        "text"
      ],
      "properties": {
        "type": {
          "const": "heading"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "text": {
          "type": "string"
        }
      }
    },
    "codeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "content"
      ],
      "properties": {
        "type": {
          "const": "code"
        },
        "language": {
          "type": "string"
        },
        "content": {
          "type": "string"
        }
      }
    },
    "imageBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "src",
        "alt"
      ],
      "properties": {
        "type": {
          "const": "image"
        },
        "src": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "quoteBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "quote"
        },
        "text": {
          "type": "string"
        },
        "attribution": {
          "type": "string"
        }
      }
    },
    "listBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ordered",
        "items"
      ],
      "properties": {
        "type": {
          "const": "list"
        },
        "ordered": {
          "type": "boolean"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
