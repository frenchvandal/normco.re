{
  "imports": {
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.1/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts",
    "lume/cms/": "https://cdn.jsdelivr.net/gh/lumeland/cms@0.14.16/",
    "jsr/assert": "jsr:@std/assert@^1.0.19",
    "jsr/testing-bdd": "jsr:@std/testing@^1.0.17/bdd",
    "npm/faker-js": "npm:@faker-js/faker@^10.3.0",
    "npm/opentelemetry-api": "npm:@opentelemetry/api@^1.9.0"
  },
  "permissions": {
    "lume": {
      "read": true,
      "write": [
        "./"
      ],
      "import": [
        "cdn.jsdelivr.net:443",
        "cdn.sheetjs.com:443",
        "jsr.io:443",
        "deno.land:443"
      ],
      "net": [
        "0.0.0.0",
        "jsr.io:443",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "fonts.googleapis.com:443",
        "fonts.gstatic.com:443",
        "registry.npmjs.org:443",
        "contrib.rocks:443",
        "localhost:4318",
        "127.0.0.1:4318"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "tasks": {
    "lume": {
      "description": "Run Lume command",
      "command": "deno run -P=lume lume/cli.ts"
    },
    "build": {
      "description": "Build the site for production",
      "command": "deno task lume"
    },
    "serve": {
      "description": "Run and serve the site for development",
      "command": "deno task lume -s"
    },
    "update-deps": {
      "description": "Update Lume and regenerate lock file",
      "command": "deno outdated --update --latest"
    },
    "check": {
      "description": "Type-check the entire project",
      "command": "deno check **/*.ts **/*.tsx"
    },
    "lint:doc": {
      "description": "Lint documentation comments (src, scripts, and plugins; root config files are excluded — they reference private Lume types by framework requirement)",
      "command": "deno doc --lint src/**/*.ts src/**/*.tsx scripts/**/*.ts plugins/**/*.ts"
    },
    "test:doc": {
      "description": "Run documentation tests from inline JSDoc examples in source files",
      "command": "deno test --doc src/**/*.ts src/**/*.tsx plugins/**/*.ts"
    },
    "lint-commit": {
      "description": "Validate the commit message against Conventional Commits (reads .git/COMMIT_EDITMSG by default)",
      "command": "deno run --allow-read scripts/lint-commit.ts"
    },
    "md-to-tsx": {
      "description": "Convert LumeCMS-generated Markdown posts (src/posts/*.md) to .page.tsx format",
      "command": "deno run --allow-read --allow-write --allow-run=deno scripts/md-to-tsx.ts"
    },
    "sync:octicons": {
      "description": "Sync the local full Octicons catalog from @primer/octicons",
      "command": "deno run --allow-net --allow-write scripts/sync-octicons.ts"
    }
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true
  },
  "unstable": [
    "temporal",
    "fmt-component"
  ],
  "lint": {
    "plugins": [
      "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.1/lint.ts"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  }
}
