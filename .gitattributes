# Normalize text files to LF in the repository and working tree.
* text=auto eol=lf

# Windows-native scripts should keep CRLF if introduced later.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets must never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.webm binary
*.wasm binary
*.zip binary
